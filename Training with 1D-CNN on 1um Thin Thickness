# ─────────────────────────────────────────────────────────────────────
# (2) Load & preprocess training data
# ─────────────────────────────────────────────────────────────────────
df_bulk = pd.read_excel(bulk_file, header=None)
df_thin = pd.read_excel(thin_file, header=None)

df_props = pd.read_excel(props_file, sheet_name=0)
df_props.columns = df_props.columns.str.strip().str.lower()
cols = ['e','sigma_y','sigma_s']
if set(cols).issubset(df_props.columns):
    props = df_props[cols].to_numpy(dtype=np.float32)
else:
    props = df_props.iloc[:, :3].to_numpy(dtype=np.float32)
p_mean, p_std = props.mean(0), props.std(0)
p_std[p_std == 0] = 1.0
props_norm = ((props - p_mean) / p_std).astype(np.float32)

n_samples = df_bulk.shape[1] // 2
n_points  = 200
u_grid    = np.linspace(0, 1, n_points, dtype=np.float32)

thin_in    = np.zeros((n_samples, n_points), dtype=np.float32)
bulk_tar   = np.zeros((n_samples, n_points), dtype=np.float32)
max_depths = np.zeros(n_samples, dtype=np.float32)

for i in range(n_samples):
    db = pd.to_numeric(df_bulk.iloc[:, 2*i],   errors='coerce').to_numpy()
    lb = pd.to_numeric(df_bulk.iloc[:, 2*i+1], errors='coerce').to_numpy()
    dt = pd.to_numeric(df_thin.iloc[:, 2*i],   errors='coerce').to_numpy()
    lt = pd.to_numeric(df_thin.iloc[:, 2*i+1], errors='coerce').to_numpy()

    md_thin = np.nanmax(dt) if not np.all(np.isnan(dt)) else 1.0
    md_bulk = np.nanmax(db) if not np.all(np.isnan(db)) else 1.0
    max_depths[i] = md_thin

    norm_dt   = dt   / (md_thin if md_thin != 0 else 1.0)
    norm_db   = db   / (md_bulk if md_bulk != 0 else 1.0)

    mask_t = (~np.isnan(norm_dt)) & (~np.isnan(lt))
    if mask_t.sum() >= 2:
        Xt = np.vstack([norm_dt[mask_t]**2, norm_dt[mask_t]]).T
        yt = lt[mask_t]
        coeffs_t, *_ = np.linalg.lstsq(Xt, yt, rcond=None)
        a_t, b_t = coeffs_t
        thin_in[i] = (a_t * u_grid**2 + b_t * u_grid).astype(np.float32)
    else:
        thin_in[i] = np.interp(u_grid, norm_dt, lt).astype(np.float32)

    mask_b = (~np.isnan(norm_db)) & (~np.isnan(lb))
    if mask_b.sum() >= 2:
        Xb = np.vstack([norm_db[mask_b]**2, norm_db[mask_b]]).T
        yb = lb[mask_b]
        coeffs_b, *_ = np.linalg.lstsq(Xb, yb, rcond=None)
        a_b, b_b = coeffs_b
        bulk_tar[i] = (a_b * u_grid**2 + b_b * u_grid).astype(np.float32)
    else:
        bulk_tar[i] = np.interp(u_grid, norm_db, lb).astype(np.float32)

global_max    = max_depths.max()
depth_channel = (u_grid * global_max).astype(np.float32)
depth_mat     = np.tile(depth_channel, (n_samples, 1)).astype(np.float32)

mask = np.isnan(thin_in).any(1) | np.isnan(bulk_tar).any(1) | np.isnan(props_norm).any(1)
thin_in, bulk_tar, props_norm, depth_mat, max_depths = [
    arr[~mask] for arr in (thin_in, bulk_tar, props_norm, depth_mat, max_depths)
]

X_load  = thin_in
X_depth = depth_mat
X_props = props_norm
y_bulk  = bulk_tar

# ─────────────────────────────────────────────────────────────────────
# (3) Train/validation split
# ─────────────────────────────────────────────────────────────────────
(Xl_tr, Xl_va,
 Xd_tr, Xd_va,
 Xp_tr, Xp_va,
 y_tr,  y_va,
 d_tr,  d_va) = train_test_split(
    X_load, X_depth, X_props, y_bulk, max_depths,
    test_size=0.2, random_state=42
)

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

train_ds = TensorDataset(
    torch.tensor(Xl_tr, dtype=torch.float32, device=device),
    torch.tensor(Xd_tr, dtype=torch.float32, device=device),
    torch.tensor(Xp_tr, dtype=torch.float32, device=device),
    torch.tensor(y_tr,  dtype=torch.float32, device=device),
)
val_ds = TensorDataset(
    torch.tensor(Xl_va, dtype=torch.float32, device=device),
    torch.tensor(Xd_va, dtype=torch.float32, device=device),
    torch.tensor(Xp_va, dtype=torch.float32, device=device),
    torch.tensor(y_va,  dtype=torch.float32, device=device),
)
train_loader = DataLoader(train_ds, batch_size=32, shuffle=True, pin_memory=True)
val_loader   = DataLoader(val_ds,   batch_size=32, pin_memory=True)

# ─────────────────────────────────────────────────────────────────────
# (4) 1D-CNN definition
# ─────────────────────────────────────────────────────────────────────
class CNN1D(nn.Module):
    def __init__(self, n_props, seq_len):
        super().__init__()
        self.conv = nn.Sequential(
            nn.Conv1d(2, 16, kernel_size=5, padding=2),
            nn.BatchNorm1d(16),
            nn.ReLU(),
            nn.MaxPool1d(2),
            nn.Conv1d(16, 32, kernel_size=5, padding=2),
            nn.BatchNorm1d(32),
            nn.ReLU(),
            nn.MaxPool1d(2),
        )
        conv_len = seq_len // 4
        self.fc = nn.Sequential(
            nn.Linear(32*conv_len + n_props, 128),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(128, seq_len),
        )

    def forward(self, load, depth, props):
        x = torch.stack([load, depth], dim=1)  # (B,2,L)
        x = self.conv(x)                       # (B,32,L/4)
        x = x.flatten(1)
        x = torch.cat([x, props], dim=1)
        return self.fc(x)

model = CNN1D(n_props=X_props.shape[1], seq_len=n_points).to(device)

# ─────────────────────────────────────────────────────────────────────
# (5) Training with early stopping
# ─────────────────────────────────────────────────────────────────────
criterion = nn.MSELoss()
optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)
best_val, wait, patience = float('inf'), 0, 10
train_losses, val_losses = [], []

for epoch in range(1, 101):
    model.train()
    t_loss = 0
    for load_b, depth_b, prop_b, y_b in train_loader:
        optimizer.zero_grad()
        out = model(load_b, depth_b, prop_b)
        loss = criterion(out, y_b)
        loss.backward()
        optimizer.step()
        t_loss += loss.item() * load_b.size(0)
    t_loss /= len(train_loader.dataset)

    model.eval()
    v_loss = 0
    with torch.no_grad():
        for load_b, depth_b, prop_b, y_b in val_loader:
            v_loss += criterion(model(load_b, depth_b, prop_b), y_b).item() * load_b.size(0)
    v_loss /= len(val_loader.dataset)

    train_losses.append(t_loss)
    val_losses.append(v_loss)
    print(f"Epoch {epoch}: Train={t_loss:.4f}, Val={v_loss:.4f}")

    if v_loss < best_val:
        best_val, wait = v_loss, 0
        torch.save(model.state_dict(), '/content/drive/MyDrive/2024 UTk Research/2024 Fall Thin Film/Substrate Correction 2025/Different Thickness Film/1 um Thickness/thin_to_bulk_best_1umthick_test.pth')
    else:
        wait += 1
        if wait >= patience:
            print("Early stopping.")
            break

model.load_state_dict(torch.load('/content/drive/MyDrive/2024 UTk Research/2024 Fall Thin Film/Substrate Correction 2025/Different Thickness Film/1 um Thickness/thin_to_bulk_best_1umthick_test.pth'))

