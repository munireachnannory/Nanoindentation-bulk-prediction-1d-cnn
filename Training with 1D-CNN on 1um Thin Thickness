    l = pd.to_numeric(df_test.iloc[:, 2*i+1], errors='coerce').to_numpy()
    td = np.nanmax(d) if not np.all(np.isnan(d)) else 1.0
    tds[i] = td
    norm_d = d / td if td != 0 else d
    mask_tt = (~np.isnan(norm_d)) & (~np.isnan(l))
    if mask_tt.sum() >= 2:
        Xt = np.vstack([norm_d[mask_tt]**2, norm_d[mask_tt]]).T
        yt = l[mask_tt]
        coeffs_tt, *_ = np.linalg.lstsq(Xt, yt, rcond=None)
        a_tt, b_tt = coeffs_tt
        thin_t[i] = (a_tt * u_grid**2 + b_tt * u_grid).astype(np.float32)
